# BUG-BOUNTY-AI Configuration
# Copy to .env and customize

# Logging
LOG_LEVEL=INFO
VERBOSITY=1  # 0=quiet, 1=normal, 2=verbose, 3=debug

# Phase 3: Async Execution
ENABLE_ASYNC=false
MAX_CONCURRENT_TOOLS=5

# Phase 4: LLM Integration
# Options: none, openai, anthropic
LLM_PROVIDER=none
LLM_MODEL=gpt-4  # or claude-3-opus for Anthropic
LLM_API_KEY=sk-...  # Your API key
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Tool Timeouts
TOOL_TIMEOUT=30
API_TIMEOUT=5
